---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

function readingTime(body: string) {
	return Math.max(1, Math.round((body?.trim().split(/\s+/).length ?? 0) / 200));
}

const tags: Record<string, [string, string, string]> = {
	'hear-the-conversation':  ['Product', '#007EF3', '#D6EBFF'],
	'introducing-the':        ['Product', '#007EF3', '#D6EBFF'],
	'why-interpret-ai':       ['Comparison', '#7977D1', '#DBDAF8'],
	'vs-google-translate':    ['Comparison', '#7977D1', '#DBDAF8'],
	'best-real-time':         ['Comparison', '#7977D1', '#DBDAF8'],
	'how-to-live-translate':  ['Tutorial', '#059669', '#d1fae5'],
	'how-to-add-live':        ['Tutorial', '#059669', '#d1fae5'],
	'how-to-broadcast':       ['Tutorial', '#059669', '#d1fae5'],
	'how-to-transcribe':      ['Tutorial', '#059669', '#d1fae5'],
};

function getTag(id: string): [string, string, string] {
	for (const [key, val] of Object.entries(tags)) {
		if (id.includes(key)) return val;
	}
	return ['Blog', '#454545', '#f3f4f6'];
}
---

<!doctype html>
<html lang="en">
<head>
	<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
</head>
<body>
	<Header />

	<!-- Hero -->
	<section class="hero">
		<div class="hero-bg" aria-hidden="true"></div>
		<div class="hero-content container">
			<div class="hero-badge">
				<span class="hero-dot"></span>
				Insights & Updates
			</div>
			<h1>The <span class="gradient-text">Interpret AI</span> Blog</h1>
			<p class="hero-sub">
				Guides, deep-dives, and product updates on real-time<br class="hide-mobile"/>
				transcription, live translation, and accessible communication.
			</p>
			<a href="https://interpretapp.ai" class="hero-cta">
				Try Interpret AI free
				<svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2.5 7h9M7.5 3.5L11 7l-3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
			</a>
		</div>
	</section>

	<!-- Featured post -->
	<main class="container">
		{posts.length > 0 && (() => {
			const featured = posts[0];
			const [tagName, tagColor, tagBg] = getTag(featured.id);
			const rt = readingTime(featured.body ?? '');
			return (
				<a href={`/blog/${featured.id}/`} class="featured-card">
					<div class="featured-inner">
						<div class="featured-badge">
							<span class="tag" style={`color:${tagColor};background:${tagBg}`}>{tagName}</span>
							<span class="tag tag-latest">Latest</span>
						</div>
						<h2 class="featured-title">{featured.data.title}</h2>
						<p class="featured-desc">{featured.data.description}</p>
						<div class="featured-meta">
							<FormattedDate date={featured.data.pubDate} />
							<span class="dot">·</span>
							<span>{rt} min read</span>
						</div>
					</div>
					<div class="featured-arrow" aria-hidden="true">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
					</div>
				</a>
			);
		})()}

		<!-- Post grid -->
		<div class="grid-header">
			<h3 class="grid-label">All articles</h3>
			<span class="grid-count">{posts.length} posts</span>
		</div>
		<ul class="post-grid">
			{posts.map((post) => {
				const [tagName, tagColor, tagBg] = getTag(post.id);
				const rt = readingTime(post.body ?? '');
				return (
					<li>
						<a href={`/blog/${post.id}/`} class="post-card">
							<span class="tag" style={`color:${tagColor};background:${tagBg}`}>{tagName}</span>
							<h4 class="card-title">{post.data.title}</h4>
							<p class="card-desc">{post.data.description}</p>
							<div class="card-meta">
								<FormattedDate date={post.data.pubDate} />
								<span class="dot">·</span>
								<span>{rt} min read</span>
							</div>
						</a>
					</li>
				);
			})}
		</ul>
	</main>

	<Footer />
</body>
</html>

<style>
/* ── Hero ── */
.hero {
	position: relative;
	overflow: hidden;
	padding: 5.5rem 0 4rem;
	text-align: center;
	background: linear-gradient(170deg, #0a1628 0%, #0d1f3c 40%, #141e33 100%);
}
.hero-bg {
	position: absolute; inset: 0;
	background:
		radial-gradient(ellipse 60% 55% at 50% -5%, rgba(0,126,243,0.35) 0%, transparent 70%),
		radial-gradient(ellipse 35% 40% at 80% 90%, rgba(121,119,209,0.25) 0%, transparent 60%),
		radial-gradient(ellipse 30% 30% at 10% 70%, rgba(0,126,243,0.15) 0%, transparent 60%);
}
.hero-content { position: relative; z-index: 1; }
.hero-badge {
	display: inline-flex; align-items: center; gap: 0.5rem;
	font-family: 'Montserrat', sans-serif;
	font-size: 0.75rem; font-weight: 700;
	letter-spacing: 0.12em; text-transform: uppercase;
	color: rgba(214,235,255,0.7);
	margin-bottom: 1.5rem;
}
.hero-dot {
	width: 7px; height: 7px; border-radius: 50%;
	background: #007EF3;
	box-shadow: 0 0 8px rgba(0,126,243,0.6);
	animation: pulse 2s ease-in-out infinite;
}
@keyframes pulse {
	0%, 100% { opacity: 1; box-shadow: 0 0 8px rgba(0,126,243,0.6); }
	50% { opacity: 0.5; box-shadow: 0 0 4px rgba(0,126,243,0.3); }
}
.hero h1 {
	color: white;
	font-size: clamp(2.2rem, 6vw, 3.4rem);
	letter-spacing: -0.035em;
	margin: 0 0 1rem;
}
.gradient-text {
	background: linear-gradient(135deg, #3ea1ff 0%, #a5a3e8 100%);
	-webkit-background-clip: text;
	-webkit-text-fill-color: transparent;
	background-clip: text;
}
.hero-sub {
	color: #8b9fc2;
	font-size: 1.05rem;
	line-height: 1.7;
	max-width: 520px;
	margin: 0 auto 2rem;
}
.hide-mobile { display: none; }
@media (min-width: 640px) { .hide-mobile { display: inline; } }
.hero-cta {
	display: inline-flex; align-items: center; gap: 0.4rem;
	background: var(--gradient);
	color: white;
	font-family: 'Montserrat', sans-serif;
	font-size: 0.9rem; font-weight: 700;
	padding: 0.7rem 1.5rem;
	border-radius: var(--radius-btn);
	transition: opacity 0.15s, transform 0.1s;
}
.hero-cta:hover { opacity: 0.9; color: white; }
.hero-cta:active { transform: scale(0.98); }

/* ── Featured ── */
main { padding: 3.5rem 1.5rem 2rem; }
.featured-card {
	display: flex;
	align-items: center;
	gap: 2rem;
	background: white;
	border: 1px solid var(--border);
	border-radius: var(--radius-card);
	padding: 2.25rem;
	margin-bottom: 3rem;
	text-decoration: none;
	color: inherit;
	transition: border-color 0.2s, box-shadow 0.25s, transform 0.15s;
}
.featured-card:hover {
	border-color: var(--blue);
	box-shadow: var(--shadow-lg);
	transform: translateY(-2px);
}
.featured-card:hover .featured-arrow { color: var(--blue); transform: translateX(4px); }
.featured-inner { flex: 1; }
.featured-badge { display: flex; gap: 0.4rem; margin-bottom: 0.85rem; }
.featured-title {
	font-size: 1.5rem;
	color: var(--black);
	line-height: 1.3;
	margin: 0 0 0.6rem;
}
.featured-desc { font-size: 0.95rem; color: var(--gray-3); margin: 0 0 1rem; line-height: 1.6; }
.featured-meta { display: flex; align-items: center; gap: 0.4rem; font-size: 0.8rem; color: var(--gray-2); font-weight: 500; }
.featured-arrow {
	flex-shrink: 0;
	color: var(--gray-1);
	transition: color 0.2s, transform 0.2s;
}

/* ── Tags ── */
.tag {
	display: inline-block;
	font-family: 'Montserrat', sans-serif;
	font-size: 0.68rem;
	font-weight: 700;
	letter-spacing: 0.06em;
	text-transform: uppercase;
	padding: 0.25em 0.75em;
	border-radius: 99px;
}
.tag-latest { background: #fef3c7; color: #92400e; }
.dot { color: var(--gray-1); }

/* ── Grid ── */
.grid-header {
	display: flex; align-items: baseline; gap: 0.75rem;
	margin-bottom: 1.5rem;
}
.grid-label {
	font-size: 0.9rem;
	font-weight: 700;
	color: var(--black);
	margin: 0;
}
.grid-count { font-size: 0.78rem; color: var(--gray-2); font-weight: 500; }
.post-grid {
	display: grid;
	grid-template-columns: repeat(3, 1fr);
	gap: 1.25rem;
	list-style: none; margin: 0; padding: 0;
}
.post-card {
	display: flex;
	flex-direction: column;
	height: 100%;
	padding: 1.75rem;
	background: white;
	border: 1px solid var(--border);
	border-radius: var(--radius-card);
	text-decoration: none;
	color: inherit;
	transition: border-color 0.2s, box-shadow 0.25s, transform 0.15s;
}
.post-card:hover {
	border-color: var(--blue);
	box-shadow: var(--shadow);
	transform: translateY(-2px);
}
.card-title {
	font-size: 1.05rem;
	color: var(--black);
	line-height: 1.35;
	margin: 0.85rem 0 0.6rem;
	flex: 1;
}
.card-desc { font-size: 0.85rem; color: var(--gray-3); line-height: 1.6; margin: 0 0 1rem; flex: 1; }
.card-meta { display: flex; align-items: center; gap: 0.4rem; font-size: 0.78rem; color: var(--gray-2); font-weight: 500; margin-top: auto; }

@media (max-width: 900px) { .post-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 580px) {
	.post-grid { grid-template-columns: 1fr; }
	.hero { padding: 4rem 0 3rem; }
	.featured-card { flex-direction: column; gap: 1rem; }
	.featured-arrow { display: none; }
}
</style>
